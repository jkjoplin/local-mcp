# Local MCP Server Configuration

# Smart model endpoint (for reasoning and general-purpose tasks)
LOCAL_MCP_SMART_URL=http://localhost:8081
LOCAL_MCP_SMART_MODEL=your-model-name-here

# Fast model endpoint (for classification and summarization)
LOCAL_MCP_FAST_URL=http://localhost:8083
LOCAL_MCP_FAST_MODEL=your-model-name-here

# Request timeout in milliseconds
LOCAL_MCP_TIMEOUT_MS=30000
