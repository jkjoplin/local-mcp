# local-mcp environment overrides
# Copy this file first:
#   cp .env.example .env

# Smart model endpoint URL.
# Default config value: http://localhost:8081
LOCAL_MCP_SMART_URL=http://localhost:8081

# Smart model ID served on the smart endpoint.
LOCAL_MCP_SMART_MODEL=mlx-community/Qwen3.5-9B-MLX-4bit

# Fast model endpoint URL.
# Default config value: http://localhost:8083
LOCAL_MCP_FAST_URL=http://localhost:8083

# Fast model ID served on the fast endpoint.
LOCAL_MCP_FAST_MODEL=mlx-community/Qwen2.5-1.5B-Instruct-4bit

# Request timeout for local model calls, in milliseconds.
LOCAL_MCP_TIMEOUT_MS=30000

# Example: Mac mini 24GB
# LOCAL_MCP_SMART_MODEL=mlx-community/Qwen3.5-9B-MLX-4bit
# LOCAL_MCP_FAST_MODEL=mlx-community/Qwen2.5-1.5B-Instruct-4bit

# Example: MacBook Pro 36GB
# LOCAL_MCP_SMART_MODEL=mlx-community/Qwen3-14B-4bit
# LOCAL_MCP_FAST_MODEL=mlx-community/Qwen2.5-1.5B-Instruct-4bit

# Example: MacBook Pro 64GB
# LOCAL_MCP_SMART_MODEL=mlx-community/Qwen3.5-27B-4bit
# LOCAL_MCP_FAST_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
